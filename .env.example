# === API Server ===
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# === Auth ===
# init_db.py가 발급한 키를 자동 주입. 처음엔 비워둠.
INITIAL_API_KEY=
API_KEY_HEADER=Authorization

# === PostgreSQL ===
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=llm_engine
POSTGRES_USER=llm
POSTGRES_PASSWORD=change_me_postgres

# === Qdrant ===
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=chunks

# === Neo4j ===
NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_neo4j

# === Redis ===
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# === vLLM (LLM - Gemma 4 26B AWQ-4bit) ===
VLLM_LLM_URL=http://vllm-gemma:8000/v1
VLLM_LLM_MODEL=cyankiwi/gemma-4-26B-A4B-it-AWQ-4bit
VLLM_LLM_MAX_TOKENS=2048
VLLM_LLM_TEMPERATURE=0.3
VLLM_LLM_MAX_MODEL_LEN=16384
VLLM_LLM_MAX_NUM_SEQS=8
VLLM_LLM_GPU_MEM_UTIL=0.55

# === vLLM (OCR - Chandra 2) ===
VLLM_OCR_URL=http://vllm-chandra:8000/v1
VLLM_OCR_MODEL=datalab-to/chandra-ocr-2
VLLM_OCR_GPU_MEM_UTIL=0.25

# === Embedding (BGE-M3) ===
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=32

# === Session ===
SESSION_TTL_SECONDS=1800
SESSION_MAX_TURNS=10
SESSION_MAX_TOKENS=4000

# === Indexing ===
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
GRAPHRAG_ENABLED=true
GRAPHRAG_WORKDIR=/data/graphrag
# Fix A: token-set seed matching (kills Korean substring false positives).
# GRAPH_SEED_USE_TOKEN_BOUNDARY=true
# GRAPH_SEED_MIN_ENTITY_LEN=2
# Fix B: order the graph+vector pool purely by cross-encoder score instead of
# prepending graph hits (requires the reranker enabled).
# GRAPH_RERANK_FUSION=true

# === Limits ===
UPLOAD_MAX_FILE_SIZE_MB=50
UPLOAD_MAX_FILES_PER_REQUEST=100
RATE_LIMIT_PER_MINUTE=60
